{
  "name": "pantry-notifications",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-01",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pantry-planner-db",
      "database_id": "local-db",
    },
  ],
  "queues": {
    "consumers": [
      {
        "queue": "pantry-notifications",
        "max_batch_size": 1,
        "max_batch_timeout": 1,
      },
    ],
  },
}
